{
  "i18n": true,
  "type": "panel",
  "items": {
    "_tariffHeader": {
      "type": "header",
      "text": "Tariff",
      "size": 3,
      "sm": 12
    },
    "fixedWorkPriceCt": {
      "type": "number",
      "label": "Work price (ct/kWh)",
      "min": 0,
      "sm": 12,
      "md": 6
    },
    "fixedBasePriceMonthlyEuro": {
      "type": "number",
      "label": "Monthly base price (EUR)",
      "min": 0,
      "sm": 12,
      "md": 6
    },
    "_gridHeader": {
      "type": "header",
      "text": "Grid",
      "size": 3,
      "sm": 12
    },
    "sourceGridImportPower": {
      "type": "objectId",
      "label": "Grid import power state",
      "sm": 12
    },
    "sourceGridExportPower": {
      "type": "objectId",
      "label": "Grid export power state",
      "sm": 12
    },
    "_houseHeader": {
      "type": "header",
      "text": "House",
      "size": 3,
      "sm": 12
    },
    "sourceHouseConsumptionPower": {
      "type": "objectId",
      "label": "House consumption power state",
      "sm": 12
    },
    "_photovoltaicsHeader": {
      "type": "header",
      "text": "Photovoltaics",
      "size": 3,
      "sm": 12
    },
    "sourcePvPower": {
      "type": "objectId",
      "label": "PV production power state",
      "sm": 12
    },
    "_batteryHeader": {
      "type": "header",
      "text": "Battery",
      "size": 3,
      "sm": 12
    },
    "sourceBatterySoc": {
      "type": "objectId",
      "label": "Battery state of charge state",
      "sm": 12
    },
    "sourceBatteryPower": {
      "type": "objectId",
      "label": "Battery power state",
      "sm": 12
    },
    "_energyAssetsHeader": {
      "type": "header",
      "text": "Energy Assets",
      "size": 3,
      "sm": 12
    },
    "energyAssets": {
      "type": "table",
      "label": "Energy assets",
      "sm": 12,
      "items": [
        {
          "type": "checkbox",
          "attr": "enabled",
          "title": "Enabled"
        },
        {
          "type": "text",
          "attr": "id",
          "title": "ID"
        },
        {
          "type": "text",
          "attr": "name",
          "title": "Name"
        },
        {
          "type": "select",
          "attr": "type",
          "title": "Type",
          "options": [
            { "label": "Grid", "value": "grid" },
            { "label": "PV", "value": "pv" },
            { "label": "Battery", "value": "battery" },
            { "label": "Consumer", "value": "consumer" },
            { "label": "EV charger", "value": "evCharger" },
            { "label": "Heat pump", "value": "heatPump" },
            { "label": "Boiler", "value": "boiler" },
            { "label": "Generator", "value": "generator" },
            { "label": "Unknown", "value": "unknown" }
          ]
        },
        {
          "type": "objectId",
          "attr": "powerStateId",
          "title": "Power state"
        },
        {
          "type": "objectId",
          "attr": "socStateId",
          "title": "State of charge state"
        },
        {
          "type": "number",
          "attr": "capacityWh",
          "title": "Capacity (Wh)"
        },
        {
          "type": "text",
          "attr": "manufacturer",
          "title": "Manufacturer"
        },
        {
          "type": "text",
          "attr": "model",
          "title": "Model"
        }
      ]
    },
    "_runtimeHeader": {
      "type": "header",
      "text": "Runtime",
      "size": 3,
      "sm": 12
    },
    "pollingIntervalSeconds": {
      "type": "number",
      "label": "Polling interval (seconds)",
      "min": 1,
      "default": 60,
      "sm": 12,
      "md": 6
    }
  }
}
